# Application Environment Variables
# No external AI API keys required. Uses local/free capabilities.

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WEBBOOK_CONTACT_EMAIL: Optional polite-contact email added to Crossref requests.
# Leave blank if you do not want to send one.
WEBBOOK_CONTACT_EMAIL=""
